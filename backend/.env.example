# Postgres direct connection — used by `npm run migrate`
# Find in: Supabase Dashboard → Project Settings → Database → URI (use the "Transaction" or "Session" pooler URL)
# Format: postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres.<ref>:<password>@...
